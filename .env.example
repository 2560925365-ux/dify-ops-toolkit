# Dify Ops Toolkit 环境变量配置
# 复制此文件为 .env 并填入真实值
# ⚠️ 警告：不要将 .env 文件提交到 Git！

# ============================================================================
# 数据库连接配置（直接连接模式）
# ============================================================================

# PostgreSQL 主机地址
DIFY_DB_HOST=localhost

# PostgreSQL 端口
DIFY_DB_PORT=5432

# 数据库名称
DIFY_DB_NAME=dify

# 数据库用户名
DIFY_DB_USER=postgres

# 数据库密码
DIFY_DB_PASSWORD=your_password_here

# ============================================================================
# Docker 模式配置（Docker exec 模式）
# ============================================================================

# Docker 容器名称（如果设置，将使用 Docker exec 而非直接连接）
# 留空则自动检测包含 "postgres" 的容器
DIFY_DOCKER_CONTAINER=

# ============================================================================
# Dify API 配置（可选，用于 API 模式）
# ============================================================================

# Dify API 地址
# DIFY_API_URL=http://localhost/v1

# Dify API 密钥（用于某些需要 API 认证的操作）
# DIFY_API_KEY=app-your-api-key

# ============================================================================
# 示例：完整配置
# ============================================================================

# Docker 模式示例：
# DIFY_DOCKER_CONTAINER=dify-postgres

# 直接连接示例：
# DIFY_DB_HOST=192.168.1.100
# DIFY_DB_PORT=5432
# DIFY_DB_NAME=dify
# DIFY_DB_USER=postgres
# DIFY_DB_PASSWORD=secure_password
